# --- App ---
ENVIRONMENT=development
API_PREFIX=/api

# --- Database ---
# Local default (SQLite). For Postgres:
# DATABASE_URL=postgresql+asyncpg://alma:alma@localhost:5432/alma
DATABASE_URL=sqlite+aiosqlite:///./alma.db

# --- Auth (seeded attorney account) ---
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720
ATTORNEY_EMAIL=attorney@alma.com
ATTORNEY_PASSWORD=changeme
ATTORNEY_NAME=Alma Attorney

# --- Email ---
# Leave RESEND_API_KEY unset to log emails to the console (no account needed).
# RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Alma <onboarding@resend.dev>
ATTORNEY_NOTIFY_EMAIL=attorney@alma.com

# --- File storage ---
STORAGE_DIR=./uploads
MAX_UPLOAD_BYTES=10485760

# --- CORS (JSON array) ---
CORS_ORIGINS=["http://localhost:3000"]
