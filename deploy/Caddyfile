# Caddy reverse proxy for the Alma stack.
# {$DOMAIN} is provided per-environment via the container env (from .env).
# Caddy provisions and renews TLS automatically for a real hostname.
#
# Same-origin routing means the browser talks only to https://{$DOMAIN}:
#   /api/*  and /health  -> backend (FastAPI)
#   everything else       -> frontend (Next.js)
# so the frontend bundle is built with NEXT_PUBLIC_API_BASE_URL=https://{$DOMAIN}.

{$DOMAIN} {
	encode zstd gzip

	@api path /api/* /health
	handle @api {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
